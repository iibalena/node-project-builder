# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/node_project_builder

# GitHub Webhooks
GITHUB_WEBHOOK_SECRET=changeme
GITHUB_TOKEN=changeme

# Runner paths (Windows)
WORKDIR=C:\builder\workdir
ARTIFACTS_DIR=C:\builder\artifacts
EXECUTABLES_DIR=C:\builder\executables
POLL_INTERVAL_MS=3000
SYNC_ON_START=true
SYNC_INTERVAL_MS=86400000
RUNNER_URL=http://localhost:3001
BUILD_COOLDOWN_MS=60000
JAVA_HOME=C:\builder\sdk\java\jdk-17.0.18+8
FLUTTER_BIN=C:\builder\sdk\flutter\bin\flutter.bat
ANDROID_HOME=C:\builder\sdk\android-sdk
ANDROID_SDK_ROOT=C:\builder\sdk\android-sdk

# Flutter Android signing (global default for appbundle)
ANDROID_KEYSTORE_PATH=C:\builder\keys\release.jks
ANDROID_KEYSTORE_STORE_PASSWORD=changeme
ANDROID_KEYSTORE_KEY_ALIAS=release
ANDROID_KEYSTORE_KEY_PASSWORD=changeme
