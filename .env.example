# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/node_project_builder

# GitHub Webhooks
GITHUB_WEBHOOK_SECRET=changeme
GITHUB_TOKEN=changeme

# Runner paths (Windows)
WORKDIR=C:\builder\workdir
ARTIFACTS_DIR=C:\builder\artifacts
EXECUTABLES_DIR=C:\builder\executables
POLL_INTERVAL_MS=3000
SYNC_ON_START=true
SYNC_INTERVAL_MS=86400000
WORKTREE_CLEANUP_INTERVAL_MS=3600000
WORKTREE_KEEP_FOR_DEBUG=false
RUNNER_URL=http://localhost:3001
BUILD_COOLDOWN_MS=60000
PR_ONLY_BUILDS=false
REPO_IGNORE_LIST=UltraSistemas/Ultra
JAVA_HOME=C:\builder\sdk\java\jdk-17.0.18+8
FLUTTER_BIN=C:\builder\sdk\flutter\bin\flutter.bat
ANDROID_HOME=C:\builder\sdk\android-sdk
ANDROID_SDK_ROOT=C:\builder\sdk\android-sdk

# Webhook validation
# MAX_WEBHOOK_AGE_MS: Rejeita webhooks mais antigos que o tempo especificado (em ms)
# Padrão: 300000 (5 minutos). Webhooks antigos receberão alerta por email.
MAX_WEBHOOK_AGE_MS=300000

# Alert e-mail (optional)
ALERT_EMAIL_TO=
ALERT_EMAIL_COOLDOWN_MS=3600000
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Publication (Google Play)
PUBLICATION_DRY_RUN=false
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=C:\builder\keys\google-play-service-account.json
PUBLICATION_AUTO_ON_PR=true
PUBLICATION_AUTO_DRY_RUN=false
PUBLICATION_DEFAULT_TRACK=internal
API_INTERNAL_URL=http://localhost:2999

# Flutter Android signing (global default for appbundle)
ANDROID_KEYSTORE_PATH=C:\builder\keys\release.jks
ANDROID_KEYSTORE_STORE_PASSWORD=changeme
ANDROID_KEYSTORE_KEY_ALIAS=release
ANDROID_KEYSTORE_KEY_PASSWORD=changeme

# Task Notification Integration (optional)
# When set, sends PUT request with build info whenever Internal App Sharing build is ready
# Payload: { owner, name, branch, prNumber, downloadUrl, expiresAt }
TASK_NOTIFICATION_WEBHOOK_URL=
TASK_NOTIFICATION_WEBHOOK_KEY=changeme
